<idea-plugin url="https://github.com/ArturUshakov/yii2-intellij-plugin">
    <id>com.yii2storm.modelmagic</id>
    <name>Yii2 Model Magic</name>
    <version>1.0.0</version>
    <vendor url="https://github.com/ArturUshakov/yii2-intellij-plugin">ArturUshakov</vendor>

    <description><![CDATA[
        <h2>Yii2 Model Magic</h2>
        <p>PhpStorm support for Yii2 model properties accessed through <code>$model-&gt;property</code>.</p>

        <h3>Current features</h3>
        <ul>
            <li>Completion from public fields, getters, setters, relations, <code>attributes()</code>, and PHPDoc.</li>
            <li>Go to Declaration for resolved properties.</li>
            <li>Type inference from declarations and PHPDoc.</li>
            <li>Inspection for unknown properties.</li>
            <li>Project-level source and priority settings.</li>
        </ul>

        <p>Array-access syntax, behavior-provided properties, and code-generating quick fixes are not implemented yet.</p>
    ]]></description>

    <change-notes><![CDATA[
        <h3>1.0.0</h3>
        <ul>
            <li>Yii2 model magic-property completion, navigation, type inference, and inspection.</li>
            <li>Configurable property sources and resolution priorities.</li>
        </ul>
    ]]></change-notes>

    <depends>com.intellij.modules.phpstorm</depends>
    <depends>com.jetbrains.php</depends>

    <extensions defaultExtensionNs="com.intellij">
        <projectService serviceImplementation="com.yii2storm.modelmagic.settings.ModelMagicProjectSettingsService"/>

        <projectConfigurable
                instance="com.yii2storm.modelmagic.settings.ModelMagicProjectConfigurable"
                id="com.yii2storm.modelmagic.settings"
                displayName="Yii2 Model Magic"/>

        <annotator
                language="PHP"
                implementationClass="com.yii2storm.modelmagic.annotator.MagicPropertyAnnotator"/>

        <completion.contributor
                language="PHP"
                implementationClass="com.yii2storm.modelmagic.completion.MagicPropertyCompletionContributor"/>

        <localInspection
                language="PHP"
                shortName="Yii2UnknownMagicProperty"
                displayName="Unknown Yii2 model magic property"
                groupName="Yii2"
                enabledByDefault="true"
                implementationClass="com.yii2storm.modelmagic.inspection.MagicPropertyInspection"/>

        <gotoDeclarationHandler
                implementation="com.yii2storm.modelmagic.navigation.MagicPropertyGotoDeclarationHandler"/>
    </extensions>

    <extensions defaultExtensionNs="com.jetbrains.php">
        <typeProvider4 implementation="com.yii2storm.modelmagic.type.MagicPropertyTypeProvider"/>
    </extensions>
</idea-plugin>
